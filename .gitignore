# Disposable venv — recreated by install_local.sh
venv/
__pycache__/
*.pyc

# Pretrained checkpoint — re-downloaded by install_local.sh
yolo11n.pt

# Training outputs (best.pt/last.pt + logs/plots) — regenerate via train.py.
# EXCEPTION: aruco_cupholder-8's best.pt (real) AND aruco_cupholder_sim's
# best.pt (sim) ARE committed (see rules below) — both are needed on the
# rosject simultaneously so inference_server.py --env sim|real can load
# either without a separate deploy step per environment. Every other run
# (older runs, last.pt, plots/logs) stays ignored/disposable. Note:
# "runs/*" (not "runs/") below — an ignored directory can't be un-ignored
# by later "!" rules, only its CONTENTS can, so every level must be
# excluded via the trailing "/*" form.
runs/*
!runs/detect/
runs/detect/*
!runs/detect/runs/
runs/detect/runs/*
!runs/detect/runs/aruco_cupholder-8/
runs/detect/runs/aruco_cupholder-8/*
!runs/detect/runs/aruco_cupholder-8/weights/
runs/detect/runs/aruco_cupholder-8/weights/*
!runs/detect/runs/aruco_cupholder-8/weights/best.pt
!runs/detect/runs/aruco_cupholder_sim/
runs/detect/runs/aruco_cupholder_sim/*
!runs/detect/runs/aruco_cupholder_sim/weights/
runs/detect/runs/aruco_cupholder_sim/weights/*
!runs/detect/runs/aruco_cupholder_sim/weights/best.pt

# Dataset images/labels (real) — images copied from ../captures/ via
# prepare_dataset.sh, labels exported from Label Studio. Keep data.yaml
# (small, hand-edited class list).
dataset/images/
dataset/labels/

# Dataset images/labels (sim) — same reasoning, images copied from
# sim_captures/ via prepare_dataset.sh.
dataset_sim/images/
dataset_sim/labels/

# Raw sim capture source images — staged into dataset_sim/ via
# prepare_dataset.sh; kept locally as the "originals" but not tracked
# (same reasoning as not tracking ../captures/, which lives outside this
# directory entirely and isn't part of this repo at all).
sim_captures/

# Debug/inspection artifacts — regenerated by aruco_pose.py / sanity_check.py
debug_output/
sanity_check_output/

# findings/ (benchmark_cascade.py's CSV + plot_cascade_benchmark.py's PNGs)
# is INTENTIONALLY NOT ignored — presentation evidence, not disposable
# debug output. Keep it tracked.
label_studio_exports/project*-train.zip
label_studio_exports/project-8-at-2026-07-20-22-09-c942d489-val.zip
